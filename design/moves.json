  "_说明": "由 Claire 设计填充，引擎只读这里。本次升级为「场景盲盒抽卡」：新增 contexts(场景) 与每个动作的 tags(约束标签)，用来按场景过滤可做的动作。新增字段是增量的——老引擎忽略它们仍可按 goal 加权随机工作。新流程/结构变更详见 design/interaction-spec.md，字段含义见 design/README.md。",

  "goals": {
    "lose": "减脂",
    "strength": "力量",
    "stretch": "拉伸"
  },

  "_contexts说明": "场景 = 一组约束上限。某动作的每个 tag 都 ≤ 该场景的 max 时，才会在这个场景被抽到。tag/max 四个维度都是 0..2，数字越小越克制：space 空间(0原地/1小范围/2需展开)、noise 声音(0静音/1轻微/2可出声)、social 社死度(0不易察觉/1正常/2随意)、posture 姿势(0坐着/1要站/2要趴躺)。想加新场景只需在这里加一条，不用改动作。",
  "contexts": {
    "office":  { "label": "🏢 办公室/工位", "max": { "space": 1, "noise": 0, "social": 0, "posture": 1 } },
    "cafe":    { "label": "☕ 咖啡厅/公共", "max": { "space": 0, "noise": 0, "social": 0, "posture": 0 } },
    "home":    { "label": "🏠 家里",        "max": { "space": 2, "noise": 2, "social": 2, "posture": 2 } },
    "hallway": { "label": "🚶 走廊/茶水间", "max": { "space": 1, "noise": 1, "social": 1, "posture": 1 } }
  },

  "config": {
    "defaultGoal": "strength",
    "defaultContext": "office",
    "drawCount": 6,
    "durationSec": 300,
    "deckHint": "抽 一 张 · 动 5 分 钟",
